# Strict Antigravity ignore rules for Unity project
# This file prevents the Antigravity agent from scanning, reading, or indexing 
# heavy binary files, cache folders, and auto-generated editor artifacts.

# ==========================================
# 1. Unity Temp & Cache Directories
# ==========================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/ExportedObj/
.gradle/

# ==========================================
# 2. Build & Packaging Artifacts
# ==========================================
/[Bb]uild/
/[Bb]uilds/
*.apk
*.aab
*.unitypackage
*.app
*.ipa
*.dmg
*.msi
*.exe

# ==========================================
# 3. IDE / Compiler Artifacts & Cache
# ==========================================
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.unityproj
*.booproj
*.tmp
*.pdb
*.mdb
*.opendb
*.VC.db
sysinfo.txt
crashlytics-build.properties

# ==========================================
# 4. Unity Meta Files
# ==========================================
# Ignore Unity metadata files to prevent token waste and search pollution
*.meta

# ==========================================
# 5. Unity Binary & Serialization Assets
# ==========================================
# Since the agent cannot read or edit these directly, ignoring them saves performance
*.unity
*.prefab
*.asset
*.controller
*.overrideController
*.anim
*.playable
*.signal
*.mask
*.mat
*.physicMaterial
*.physicsMaterial2D
*.guiskin
*.fontsettings

# ==========================================
# 6. Media, 3D Models, and Audio (Binaries)
# ==========================================
# Images & Textures
*.png
*.jpg
*.jpeg
*.tga
*.psd
*.tiff
*.gif
*.bmp
*.exr
*.hdr
*.tif
*.iff
*.pict
*.svg

# 3D Models & Meshes
*.fbx
*.obj
*.max
*.blend
*.ma
*.mb
*.3ds
*.dae
