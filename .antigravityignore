*.s3m
*.midi
*.mid

# Video Files
*.mp4
*.mov
*.avi
*.asf
*.asx
*.wmv
*.m4v
*.ogv

# Fonts
*.ttf
*.otf
*.ttc
*.dfont
*.woff
*.woff2

# Compressed Archives
*.zip
*.rar
*.tar
*.gz
*.7z
*.tgz

# Compiled Libraries
*.dll
*.so
*.dylib
*.jar
*.aar
*.lib
*.a

# ==========================================
# 7. Static / Third-Party Project Folders
# ==========================================
# These contain third-party scripts, assets, or tools that do not require editing.
# Ignoring them prevents the agent from searching them during codebase queries.
/Assets/TextMesh Pro/
/Assets/ThirdParty/
/Assets/CrazyOptimizer/
/Assets/Plugins/Editor/JetBrains*
/Assets/AssetStoreTools*
